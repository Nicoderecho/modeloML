{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Análisis de Rendimiento de Inversiones de Congresistas\n",
    "\n",
    "Este notebook analiza el rendimiento de las inversiones de congresistas del Senado de EE.UU. durante el periodo 2014-2024, comparándolas con benchmarks del mercado y cruzando con información política (comisiones, partidos, cargos).\n",
    "\n",
    "## Objetivos\n",
    "\n",
    "1. Calcular retornos reales de compras y ventas\n",
    "2. Comparar rendimiento vs S&P 500\n",
    "3. Analizar diferencias por partido, cargo y comisión\n",
    "4. Identificar correlaciones estadísticamente significativas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Importar librerías\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Configurar estilo de gráficos\n",
    "sns.set_style('whitegrid')\n",
    "sns.set_palette('husband')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "plt.rcParams['font.size'] = 12"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Carga de Datos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar datos enriquecidos con retornos\n",
    "df_transacciones = pd.read_csv('../datos/processed/transacciones_con_retornos.csv')\n",
    "\n",
    "# Cargar información de congresistas\n",
    "df_info = pd.read_csv('../datos/processed/congresistas_info.csv')\n",
    "\n",
    "print(f'Transacciones: {len(df_transacciones)}')\n",
    "print(f'Congresistas: {len(df_info)}')\n",
    "print(f'\\nColumnas transacciones: {list(df_transacciones.columns)}')\n",
    "print(f'Columnas info: {list(df_info.columns)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Vista preliminar de los datos\n",
    "df_transacciones[['Name', 'Ticker', 'Type', 'Transaction.Date', 'retorno_porcentual', 'alpha']].head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Análisis Exploratorio de Retornos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Estadísticas descriptivas de retornos\n",
    "df_validos = df_transacciones[df_transacciones['retorno_porcentual'].notna()]\n",
    "\n",
    "print('=== ESTADÍSTICAS DE RETORNOS ===')\n",
    "print(f'Retorno promedio: {df_validos[\"retorno_porcentual\"].mean()*100:.2f}%')\n",
    "print(f'Retorno mediano: {df_validos[\"retorno_porcentual\"].median()*100:.2f}%')\n",
    "print(f'Retorno std: {df_validos[\"retorno_porcentual\"].std()*100:.2f}%')\n",
    "print(f'Mínimo: {df_validos[\"retorno_porcentual\"].min()*100:.2f}%')\n",
    "print(f'Máximo: {df_validos[\"retorno_porcentual\"].max()*100:.2f}%')\n",
    "print(f'Win rate: {(df_validos[\"retorno_porcentual\"] > 0).mean()*100:.1f}%')\n",
    "print(f'Skewness: {df_validos[\"retorno_porcentual\"].skew():.2f}')\n",
    "print(f'Kurtosis: {df_validos[\"retorno_porcentual\"].kurtosis():.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribución de retornos\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# Histograma\n",
    "axes[0, 0].hist(df_validos['retorno_porcentual'], bins=50, edgecolor='black', alpha=0.7)\n",
    "axes[0, 0].axvline(0, color='red', linestyle='--', linewidth=2)\n",
    "axes[0, 0].set_xlabel('Retorno (%)')\n",
    "axes[0, 0].set_ylabel('Frecuencia')\n",
    "axes[0, 0].set_title('Distribución de Retornos')\n",
    "\n",
    "# Boxplot\n",
    "axes[0, 1].boxplot(df_validos['retorno_porcentual'].dropna())\n",
    "axes[0, 1].axhline(0, color='red', linestyle='--')\n",
    "axes[0, 1].set_ylabel('Retorno (%)')\n",
    "axes[0, 1].set_title('Boxplot de Retornos')\n",
    "\n",
    "# Retornos por año\n",
    "df_validos['año'] = pd.to_datetime(df_validos['Transaction.Date']).dt.year\n",
    "retorno_por_año = df_validos.groupby('año')['retorno_porcentual'].agg(['mean', 'std', 'count'])\n",
    "axes[1, 0].plot(retorno_por_año.index, retorno_por_año['mean']*100, marker='o')\n",
    "axes[1, 0].axhline(0, color='gray', linestyle='--')\n",
    "axes[1, 0].set_xlabel('Año')\n",
    "axes[1, 0].set_ylabel('Retorno Promedio (%)')\n",
    "axes[1, 0].set_title('Retorno Promedio por Año')\n",
    "\n",
    "# Win rate por año\n",
    "win_rate_por_año = df_validos.groupby('año').apply(lambda x: (x['retorno_porcentual'] > 0).mean())\n",
    "axes[1, 1].bar(win_rate_por_año.index, win_rate_por_año.values)\n",
    "axes[1, 1].axhline(0.5, color='gray', linestyle='--')\n",
    "axes[1, 1].set_xlabel('Año')\n",
    "axes[1, 1].set_ylabel('Win Rate')\n",
    "axes[1, 1].set_title('Win Rate por Año')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/distribucion_retornos.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Rendimiento por Partido Político"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge con información de partido\n",
    "df_merged = df_validos.merge(\n",
    "    df_info[['name', 'partido', 'es_chair', 'es_ranking', 'comision_banking', 'anos_en_congreso']],\n",
    "    left_on=df_validos['Name'].str.strip().str.lower(),\n",
    "    right_on=df_info['name'].str.strip().str.lower(),\n",
    "    how='left'\n",
    ")\n",
    "df_merged['partido'] = df_merged['partido'].fillna('U')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rendimiento por partido\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    # Bar chart de retorno promedio\n",
    "retorno_por_partido = df_merged.groupby('partido')['retorno_porcentual'].agg(['mean', 'std', 'count'])\n",
    "colors = {'D': 'blue', 'R': 'red', 'U': 'gray'}\n",
    "bars = axes[0].bar(retorno_por_partido.index, retorno_por_partido['mean']*100, \n",
    "                   color=[colors.get(x, 'gray') for x in retorno_por_partido.index])\n",
    "axes[0].axhline(0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[0].set_xlabel('Partido')\n",
    "axes[0].set_ylabel('Retorno Promedio (%)')\n",
    "axes[0].set_title('Retorno Promedio por Partido')\n",
    "\n",
    "# Añadir etiquetas con número de operaciones\n",
    "for i, (idx, row) in enumerate(retorno_por_partido.iterrows()):\n",
    "    axes[0].text(i, row['mean']*100, f'n={int(row[\"count\"])}', ha='center', va='bottom')\n",
    "\n",
    "# Boxplot comparativo\n",
    "datos_boxplot = [df_merged[df_merged['partido'] == p]['retorno_porcentual'].dropna() for p in ['D', 'R', 'U']]\n",
    "axes[1].boxplot(datos_boxplot, labels=['Demócrata', 'Republicano', 'Unknown'])\n",
    "axes[1].axhline(0, color='red', linestyle='--')\n",
    "axes[1].set_ylabel('Retorno (%)')\n",
    "axes[1].set_title('Distribución de Retornos por Partido')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/rendimiento_por_partido.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test estadístico: t-test entre D y R\n",
    "from scipy import stats\n",
    "\n",
    "retornos_d = df_merged[df_merged['partido'] == 'D']['retorno_porcentual'].dropna()\n",
    "retornos_r = df_merged[df_merged['partido'] == 'R']['retorno_porcentual'].dropna()\n",
    "\n",
    "t_stat, p_value = stats.ttest_ind(retornos_d, retornos_r, equal_var=False)\n",
    "\n",
    "print('=== T-TEST: D vs R ===')\n",
    "print(f'D: mean={retornos_d.mean()*100:.2f}%, std={retornos_d.std()*100:.2f}%, n={len(retornos_d)}')\n",
    "print(f'R: mean={retornos_r.mean()*100:.2f}%, std={retornos_r.std()*100:.2f}%, n={len(retornos_r)}')\n",
    "print(f't-statistic: {t_stat:.3f}')\n",
    "print(f'p-value: {p_value:.4f}')\n",
    "print(f'Significativo: {p_value < 0.05}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Rendimiento por Tipo de Cargo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clasificar por tipo de cargo\n",
    "def clasificar_cargo(row):\n",
    "    if row.get('es_chair', 0) == 1:\n",
    "        return 'Chair'\n",
    "    elif row.get('es_ranking', 0) == 1:\n",
    "        return 'Ranking'\n",
    "    else:\n",
    "        return 'Member'\n",
    "\n",
    "df_merged['tipo_cargo'] = df_merged.apply(clasificar_cargo, axis=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rendimiento por tipo de cargo\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    # Retorno promedio por cargo\n",
    "retorno_por_cargo = df_merged.groupby('tipo_cargo')['retorno_porcentual'].agg(['mean', 'std', 'count'])\n",
    "colors_cargo = {'Chair': 'green', 'Ranking': 'orange', 'Member': 'purple'}\n",
    "bars = axes[0].bar(retorno_por_cargo.index, retorno_por_cargo['mean']*100,\n",
    "                   color=[colors_cargo.get(x, 'gray') for x in retorno_por_cargo.index])\n",
    "axes[0].axhline(0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[0].set_xlabel('Tipo de Cargo')\n",
    "axes[0].set_ylabel('Retorno Promedio (%)')\n",
    "axes[0].set_title('Retorno Promedio por Tipo de Cargo')\n",
    "\n",
    "# Añadir etiquetas\n",
    "for i, (idx, row) in enumerate(retorno_por_cargo.iterrows()):\n",
    "    axes[0].text(i, row['mean']*100, f'n={int(row[\"count\"])}', ha='center', va='bottom')\n",
    "\n",
    "# Boxplot\n",
    "datos_boxplot_cargo = [df_merged[df_merged['tipo_cargo'] == c]['retorno_porcentual'].dropna() \n",
    "                       for c in ['Chair', 'Ranking', 'Member']]\n",
    "axes[1].boxplot(datos_boxplot_cargo, labels=['Chair', 'Ranking', 'Member'])\n",
    "axes[1].axhline(0, color='red', linestyle='--')\n",
    "axes[1].set_ylabel('Retorno (%)')\n",
    "axes[1].set_title('Distribución de Retornos por Cargo')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/rendimiento_por_cargo.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# T-test: Chairs vs Members\n",
    "retornos_chair = df_merged[df_merged['tipo_cargo'] == 'Chair']['retorno_porcentual'].dropna()\n",
    "retornos_member = df_merged[df_merged['tipo_cargo'] == 'Member']['retorno_porcentual'].dropna()\n",
    "\n",
    "t_stat_chair, p_value_chair = stats.ttest_ind(retornos_chair, retornos_member, equal_var=False)\n",
    "\n",
    "print('=== T-TEST: Chair vs Member ===')\n",
    "print(f'Chair: mean={retornos_chair.mean()*100:.2f}%, n={len(retornos_chair)}')\n",
    "print(f'Member: mean={retornos_member.mean()*100:.2f}%, n={len(retornos_member)}')\n",
    "print(f't-statistic: {t_stat_chair:.3f}')\n",
    "print(f'p-value: {p_value_chair:.4f}')\n",
    "print(f'Significativo: {p_value_chair < 0.05}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Rendimiento por Sector de Comisión"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identificar sector de comisión para cada congresista\n",
    "sectores = ['banking', 'energy', 'health', 'judiciary', 'foreign']\n",
    "\n",
    "def obtener_sector(row):\n",
    "    for sector in sectores:\n",
    "        if row.get(f'comision_{sector}', 0) == 1:\n",
    "            return sector\n",
    "    return 'other'\n",
    "\n",
    "df_merged['sector'] = df_merged.apply(obtener_sector, axis=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Heatmap: Retorno por sector × partido\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "retorno_sector_partido = df_merged.groupby(['sector', 'partido'])['retorno_porcentual'].mean().unstack()\n",
    "\n",
    "sns.heatmap(retorno_sector_partido*100, annot=True, fmt='.1f', cmap='RdYlGn', center=0,\n",
    "            ax=ax, cbar_kws={'label': 'Retorno (%)'})\n",
    "ax.set_xlabel('Partido')\n",
    "ax.set_ylabel('Sector de Comisión')\n",
    "ax.set_title('Heatmap: Retorno Promedio por Sector × Partido')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/heatmap_sector_partido.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ANOVA: Diferencia de retornos por sector\n",
    "from scipy import stats\n",
    "\n",
    "datos_sectores = [df_merged[df_merged['sector'] == s]['retorno_porcentual'].dropna() for s in sectores + ['other']]\n",
    "datos_sectores = [d for d in datos_sectores if len(d) > 10]  # Filtrar sectores con pocos datos\n",
    "\n",
    "if len(datos_sectores) >= 2:\n",
    "    f_stat, p_value = stats.f_oneway(*datos_sectores)\n",
    "    print('=== ANOVA: Retornos por Sector ===')\n",
    "    print(f'F-statistic: {f_stat:.3f}')\n",
    "    print(f'p-value: {p_value:.4f}')\n",
    "    print(f'Significativo: {p_value < 0.05}')\n",
    "    \n",
    "    for i, sector in enumerate(['banking', 'energy', 'health', 'judiciary', 'foreign', 'other']):\n",
    "        if len(datos_sectores) > i:\n",
    "            print(f'{sector}: mean={datos_sectores[i].mean()*100:.2f}%, n={len(datos_sectores[i])}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Comparación vs S&P 500 (Alpha)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Análisis de Alpha (outperformance vs S&P 500)\n",
    "df_con_alpha = df_merged[df_merged['alpha'].notna()]\n",
    "\n",
    "print('=== ALPHA VS S&P 500 ===')\n",
    "print(f'Alpha promedio: {df_con_alpha[\"alpha\"].mean()*100:.2f}%')\n",
    "print(f'Alpha mediano: {df_con_alpha[\"alpha\"].median()*100:.2f}%')\n",
    "print(f'% operaciones con alpha positivo: {(df_con_alpha[\"alpha\"] > 0).mean()*100:.1f}%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribución de Alpha\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Histograma de alpha\n",
    "axes[0].hist(df_con_alpha['alpha'], bins=50, edgecolor='black', alpha=0.7, color='orange')\n",
    "axes[0].axvline(0, color='red', linestyle='--', linewidth=2)\n",
    "axes[0].set_xlabel('Alpha (%)')\n",
    "axes[0].set_ylabel('Frecuencia')\n",
    "axes[0].set_title('Distribución de Alpha vs S&P 500')\n",
    "\n",
    "# Alpha por partido\n",
    "alpha_por_partido = df_con_alpha.groupby('partido')['alpha'].agg(['mean', 'count'])\n",
    "bars = axes[1].bar(alpha_por_partido.index, alpha_por_partido['mean']*100,\n",
    "                   color=[colors.get(x, 'gray') for x in alpha_por_partido.index])\n",
    "axes[1].axhline(0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[1].set_xlabel('Partido')\n",
    "axes[1].set_ylabel('Alpha Promedio (%)')\n",
    "axes[1].set_title('Alpha vs S&P 500 por Partido')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/alpha_sp500.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Top 10 Congresistas por Rendimiento"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular métricas por congresista\n",
    "metricas_por_congresista = df_validos.groupby('Name').agg({\n",
    "    'retorno_porcentual': ['mean', 'std', 'count'],\n",
    "    'alpha': 'mean' if 'alpha' in df_validos.columns else lambda x: np.nan\n",
    "}).reset_index()\n",
    "\n",
    "# Renombrar columnas\n",
    "metricas_por_congresista.columns = ['name', 'retorno_promedio', 'retorno_std', 'n_operaciones', 'alpha_promedio']\n",
    "\n",
    "# Filtrar congresistas con al menos 20 operaciones\n",
    "metricas_filtrado = metricas_por_congresista[metricas_por_congresista['n_operaciones'] >= 20]\n",
    "\n",
    "# Top 10 por retorno promedio\n",
    "top_10_retorno = metricas_filtrado.nlargest(10, 'retorno_promedio')\n",
    "bottom_10_retorno = metricas_filtrado.nsmallest(10, 'retorno_promedio')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualización: Top 10\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 8))\n",
    "\n",
    # Top 10 por retorno\n",
    "axes[0].barh(top_10_retorno['name'], top_10_retorno['retorno_promedio']*100, color='green')\n",
    "axes[0].set_xlabel('Retorno Promedio (%)')\n",
    "axes[0].set_title('Top 10 Congresistas por Retorno')\n",
    "axes[0].invert_yaxis()\n",
    "\n",
    # Bottom 10 por retorno\n",
    "axes[1].barh(bottom_10_retorno['name'], bottom_10_retorno['retorno_promedio']*100, color='red')\n",
    "axes[1].set_xlabel('Retorno Promedio (%)')\n",
    "axes[1].set_title('Bottom 10 Congresistas por Retorno')\n",
    "axes[1].invert_yaxis()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/top_bottom_congresistas.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mostrar tabla con información adicional\n",
    "top_10_con_info = top_10_retorno.merge(df_info[['name', 'partido', 'es_chair', 'comision_banking']], \n",
    "                                        left_on='name', right_on='name', how='left')\n",
    "top_10_con_info[['name', 'partido', 'retorno_promedio', 'alpha_promedio', 'n_operaciones', 'es_chair', 'comision_banking']]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Rendimiento por Tipo de Operación (Compra vs Venta)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clasificar tipo de operación\n",
    "df_merged['tipo_operacion'] = df_merged['Type'].apply(\n",
    "    lambda x: 'Compra' if 'Purchase' in x else ('Venta' if 'Sale' in x else 'Otro')\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Comparar compras vs ventas\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    # Retorno promedio por tipo\n",
    "retorno_por_tipo = df_merged.groupby('tipo_operacion')['retorno_porcentual'].agg(['mean', 'count'])\n",
    "colors_tipo = {'Compra': 'green', 'Venta': 'red', 'Otro': 'gray'}\n",
    "\n",
    "bars = axes[0].bar(retorno_por_tipo.index, retorno_por_tipo['mean']*100,\n",
    "                   color=[colors_tipo.get(x, 'gray') for x in retorno_por_tipo.index])\n",
    "axes[0].axhline(0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[0].set_xlabel('Tipo de Operación')\n",
    "axes[0].set_ylabel('Retorno Promedio (%)')\n",
    "axes[0].set_title('Retorno por Tipo de Operación')\n",
    "\n",
    # Añadir etiquetas\n",
    "for i, (idx, row) in enumerate(retorno_por_tipo.iterrows()):\n",
    "    axes[0].text(i, row['mean']*100, f'n={int(row[\"count\"])}', ha='center', va='bottom')\n",
    "\n",
    # Boxplot\n",
    "datos_boxplot_tipo = [df_merged[df_merged['tipo_operacion'] == t]['retorno_porcentual'].dropna() \n",
    "                      for t in ['Compra', 'Venta']]\n",
    "axes[1].boxplot(datos_boxplot_tipo, labels=['Compra', 'Venta'])\n",
    "axes[1].axhline(0, color='red', linestyle='--')\n",
    "axes[1].set_ylabel('Retorno (%)')\n",
    "axes[1].set_title('Distribución: Compra vs Venta')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reportes/retorno_por_tipo_operacion.png', dpi=150)\n",
    "plt.show()"
